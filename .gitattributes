# Auto detect text files and perform LF normalization
* text=auto

# Docker files
*.dockerfile text eol=lf
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf
docker-compose*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf

# Config files
*.conf text eol=lf
*.ini text eol=lf

# Documentation
*.md text eol=lf
README* text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf

